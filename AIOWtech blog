<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>AIOWtech • Frontier Intelligence Blog</title>
  <!-- Google Fonts & Font Awesome -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- marked.js for Markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #f8fafc;
      --surface: #ffffff;
      --text-primary: #0f172a;
      --text-secondary: #334155;
      --accent: #3b82f6;
      --accent-dark: #2563eb;
      --border: #e2e8f0;
      --card-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.02);
      --tag-bg: #eef2ff;
      --footer-bg: #f1f5f9;
      --transition: all 0.25s ease;
    }

    body.dark {
      --bg: #0f172a;
      --surface: #1e293b;
      --text-primary: #f1f5f9;
      --text-secondary: #cbd5e1;
      --border: #334155;
      --tag-bg: #2d3a5e;
      --footer-bg: #0f172a;
      --card-shadow: 0 10px 25px -5px rgba(0,0,0,0.3);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      transition: background 0.3s ease, color 0.2s ease;
      line-height: 1.5;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* modern navbar */
    .navbar {
      backdrop-filter: blur(12px);
      background: rgba(var(--bg-rgb), 0.8);
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 1rem 0;
    }
    .nav-flex {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .logo {
      font-size: 1.8rem;
      font-weight: 800;
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .logo span { font-weight: 300; color: var(--text-secondary); background: none; }
    .nav-links {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--text-primary);
      font-weight: 500;
      transition: var(--transition);
    }
    .nav-links a:hover { color: var(--accent); }
    .theme-toggle {
      background: var(--tag-bg);
      border: none;
      font-size: 1.2rem;
      cursor: pointer;
      border-radius: 2rem;
      width: 2.5rem;
      height: 2.5rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--text-primary);
      transition: var(--transition);
    }
    .theme-toggle:hover { background: var(--accent); color: white; }

    /* search & filters */
    .search-section {
      margin: 2rem 0 1rem;
    }
    .search-wrapper {
      display: flex;
      gap: 0.75rem;
      max-width: 550px;
    }
    .search-wrapper input {
      flex: 1;
      padding: 0.85rem 1.2rem;
      border-radius: 60px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text-primary);
      font-size: 1rem;
      font-weight: 500;
      transition: var(--transition);
    }
    .search-wrapper input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }
    .search-wrapper button {
      background: var(--accent);
      border: none;
      padding: 0 1.8rem;
      border-radius: 60px;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }
    .search-wrapper button:hover { background: var(--accent-dark); transform: scale(0.97); }

    /* tags chips */
    .tags-filter {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin: 1.5rem 0 2rem;
    }
    .tag-chip {
      background: var(--tag-bg);
      padding: 0.45rem 1.2rem;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      color: var(--text-primary);
      backdrop-filter: blur(2px);
    }
    .tag-chip.active, .tag-chip:hover {
      background: var(--accent);
      color: white;
      transform: translateY(-2px);
    }

    /* featured section */
    .featured {
      background: linear-gradient(145deg, var(--surface), var(--bg));
      border-radius: 2rem;
      padding: 2rem;
      margin: 1rem 0 2rem;
      border: 1px solid var(--border);
      transition: var(--transition);
    }
    .featured-badge {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .featured h2 {
      font-size: 1.8rem;
      margin: 0.5rem 0;
    }
    .featured .featured-meta {
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }
    .read-btn {
      background: var(--accent);
      border: none;
      padding: 0.6rem 1.5rem;
      border-radius: 40px;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      margin-top: 0.5rem;
    }
    .read-btn:hover { background: var(--accent-dark); transform: translateX(5px); }

    /* blog grid */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      margin: 2rem 0 3rem;
    }
    .post-card {
      background: var(--surface);
      border-radius: 1.5rem;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
      transition: transform 0.25s, box-shadow 0.3s;
      cursor: pointer;
      display: flex;
      flex-direction: column;
    }
    .post-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.2);
    }
    .card-img {
      width: 100%;
      height: 210px;
      object-fit: cover;
      background: #334155;
      transition: transform 0.4s;
    }
    .post-card:hover .card-img { transform: scale(1.02); }
    .card-content {
      padding: 1.5rem;
      flex: 1;
    }
    .card-title {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }
    .card-meta {
      display: flex;
      justify-content: space-between;
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin: 0.6rem 0;
    }
    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.8rem;
    }
    .card-tag {
      background: var(--tag-bg);
      padding: 0.2rem 0.8rem;
      border-radius: 30px;
      font-size: 0.7rem;
      font-weight: 600;
    }

    /* loading animation */
    .loader {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 400px;
      flex-direction: column;
      gap: 1rem;
    }
    .spinner {
      width: 52px;
      height: 52px;
      border: 5px solid var(--border);
      border-top: 5px solid var(--accent);
      border-radius: 50%;
      animation: spin 0.9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loader p { color: var(--accent); font-weight: 500; }

    /* individual post page */
    .post-page {
      max-width: 800px;
      margin: 2rem auto;
      background: var(--surface);
      border-radius: 2rem;
      padding: 2rem;
      border: 1px solid var(--border);
      animation: fadeUp 0.4s ease;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px);}
      to { opacity: 1; transform: translateY(0);}
    }
    .post-page img {
      max-width: 100%;
      border-radius: 1.5rem;
      margin: 1.2rem 0;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    .post-page h1 {
      font-size: 2.4rem;
      margin: 0.5rem 0 0.5rem;
    }
    .post-meta-detail {
      display: flex;
      gap: 1.5rem;
      margin: 1rem 0;
      color: var(--text-secondary);
      font-size: 0.9rem;
      flex-wrap: wrap;
    }
    .post-content {
      font-size: 1.05rem;
      line-height: 1.7;
      margin-top: 1.5rem;
    }
    .post-content p { margin: 1rem 0; }
    .post-content h2, .post-content h3 { margin: 1.5rem 0 0.5rem; }
    .back-btn {
      background: none;
      border: none;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 1.5rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 1rem;
      transition: var(--transition);
    }
    .back-btn:hover { gap: 0.9rem; color: var(--accent-dark); }

    /* footer branding */
    footer {
      background: var(--footer-bg);
      margin-top: 4rem;
      padding: 2.5rem 0;
      text-align: center;
      border-top: 1px solid var(--border);
      color: var(--text-secondary);
    }
    .footer-brand {
      font-weight: 600;
      font-size: 1.2rem;
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    @media (max-width: 700px) {
      .nav-flex { flex-direction: column; }
      .blog-grid { grid-template-columns: 1fr; }
      .post-page { padding: 1.5rem; margin: 1rem; }
      .featured h2 { font-size: 1.5rem; }
    }
    .hidden { display: none; }
    .no-results {
      text-align: center;
      padding: 3rem;
      font-size: 1.2rem;
      background: var(--surface);
      border-radius: 2rem;
      border: 1px solid var(--border);
    }
  </style>
</head>
<body>

<nav class="navbar">
  <div class="container nav-flex">
    <div class="logo">AIOW<span>tech</span></div>
    <div class="nav-links">
      <a href="#" id="homeLink"><i class="fas fa-home"></i> Home</a>
      <button class="theme-toggle" id="darkModeToggle" aria-label="Dark mode"><i class="fas fa-moon"></i></button>
    </div>
  </div>
</nav>

<main class="container" id="appRoot">
  <div id="mainContent"></div>
</main>

<footer>
  <div class="container">
    <div class="footer-brand">AIOWtech</div>
    <p style="margin-top: 0.8rem;">intelligent systems · shaping the future of AI & emerging tech</p>
    <p style="margin-top: 0.5rem; font-size: 0.8rem;"><i class="fas fa-globe"></i> © 2025 — frontier intelligence for a connected world</p>
  </div>
</footer>

<script>
  // ======================== BLOG CORE ========================
  // 3 default posts covering latest tech & world updates
  const DEFAULT_POSTS = [
    {
      slug: "the-rise-of-autonomous-agents-2025",
      title: "The Rise of Autonomous AI Agents: What's Next in 2025",
      date: "April 2, 2025",
      image: "https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&auto=format",
      tags: ["AI", "Innovation", "Future Tech"],
      content: `## The new era of autonomous intelligence

The world of artificial intelligence is witnessing a paradigm shift. From LLMs to **autonomous agents** that can execute multi-step tasks without human intervention. Companies like AIOWtech are at the forefront, developing agentic workflows that revolutionize how we interact with software.

### Key breakthroughs in 2025
- **Self-correcting reasoning loops**: Agents now verify their own outputs.
- **Cross-platform orchestration**: Seamless API integration across enterprise tools.
- **Human-in-the-loop guardrails**: Ethical frameworks built into agent logic.

> "Autonomous agents will be as transformative as the internet was in the 90s." — AIOWtech Research

As these systems mature, we're seeing real-world deployments in logistics, customer support, and creative workflows. The future is not just generative — it's **agentic**.`
    },
    {
      slug: "global-climate-tech-breakthroughs",
      title: "Climate Tech Breakthroughs: How AI is Saving the Planet",
      date: "March 28, 2025",
      image: "https://images.unsplash.com/photo-1611273426858-450eac8e9d9c?w=800&auto=format",
      tags: ["Sustainability", "Climate", "World Impact"],
      content: `## Leveraging AI for a greener tomorrow

From optimizing renewable grids to detecting methane leaks via satellite imagery, artificial intelligence is becoming Earth's greatest ally. Recent global collaborations highlight how machine learning reduces carbon footprints across industries.

### Recent achievements
- **Energy grid optimization** reduced waste by 18% in pilot cities.
- **Precision agriculture** using AI-driven irrigation saves trillions of liters of water.
- **Carbon capture simulation** accelerated by generative models.

The tech community is uniting under initiatives like "AI for Climate", with AIOWtech contributing open-source models for environmental monitoring. Together, we are building a sustainable future powered by intelligence and compassion.`
    },
    {
      slug: "next-gen-computing-quantum-edge",
      title: "Next-Gen Computing: Quantum & Edge Synergy",
      date: "March 20, 2025",
      image: "https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=800&auto=format",
      tags: ["Quantum", "Edge Computing", "Hardware"],
      content: `## When quantum meets the edge

The convergence of quantum algorithms and edge devices is unlocking possibilities once considered science fiction. Hybrid classical-quantum models are now being deployed in real-time anomaly detection and drug discovery pipelines.

### Why this matters globally
- **Ultra-low latency inference** for autonomous systems.
- **Cryptography ready for post-quantum era**.
- **Distributed quantum machine learning** across edge nodes.

AIOWtech's research labs are prototyping quantum-inspired tensor networks that run efficiently on edge TPUs. The fusion of these technologies will redefine cybersecurity, logistics, and smart cities by 2027. Stay tuned for our upcoming whitepaper.`
    }
  ];

  let allPosts = [];         // full posts array with parsed html
  let currentFilterTag = 'all';
  let currentSearchTerm = '';

  const mainContainer = document.getElementById('mainContent');

  // Helper: convert markdown to HTML via marked
  function renderMarkdown(md) {
    if (!md) return '';
    return marked.parse(md);
  }

  // Initialize posts from defaults + add any future dynamic if needed
  async function initPosts() {
    // simulate loading delay for smooth loading animation
    return new Promise((resolve) => {
      setTimeout(() => {
        allPosts = DEFAULT_POSTS.map(post => ({
          ...post,
          contentHtml: renderMarkdown(post.content),
          rawContent: post.content
        }));
        resolve();
      }, 300);
    });
  }

  // Filter logic based on tag & search
  function getFilteredPosts() {
    let filtered = [...allPosts];
    if (currentFilterTag !== 'all') {
      filtered = filtered.filter(p => p.tags.map(t => t.toLowerCase()).includes(currentFilterTag.toLowerCase()));
    }
    if (currentSearchTerm.trim() !== '') {
      const term = currentSearchTerm.toLowerCase();
      filtered = filtered.filter(p => 
        p.title.toLowerCase().includes(term) || 
        p.tags.some(t => t.toLowerCase().includes(term)) ||
        p.content.toLowerCase().includes(term)
      );
    }
    return filtered;
  }

  // Extract unique tags from posts
  function getAllTags() {
    const tagsSet = new Set();
    allPosts.forEach(p => p.tags.forEach(t => tagsSet.add(t)));
    return Array.from(tagsSet).sort();
  }

  // Escape HTML
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
      return c;
    });
  }

  // Render home page (grid + featured + search + tags)
  function renderHome() {
    const filtered = getFilteredPosts();
    const allTags = getAllTags();
    const featuredPost = allPosts.length > 0 ? allPosts[0] : null;

    const html = `
      <div class="search-section">
        <div class="search-wrapper">
          <input type="text" id="searchInput" placeholder="Search articles, topics, or keywords..." value="${escapeHtml(currentSearchTerm)}">
          <button id="searchBtn"><i class="fas fa-search"></i> Search</button>
        </div>
        <div class="tags-filter" id="tagsFilterContainer">
          <div class="tag-chip ${currentFilterTag === 'all' ? 'active' : ''}" data-tag="all">✨ All</div>
          ${allTags.map(tag => `<div class="tag-chip ${currentFilterTag === tag ? 'active' : ''}" data-tag="${escapeHtml(tag)}">#${escapeHtml(tag)}</div>`).join('')}
        </div>
      </div>
      ${featuredPost ? `
        <div class="featured">
          <div class="featured-badge"><i class="fas fa-bolt"></i> FEATURED INSIGHT</div>
          <h2>${escapeHtml(featuredPost.title)}</h2>
          <div class="featured-meta"><i class="far fa-calendar-alt"></i> ${featuredPost.date} &nbsp;•&nbsp; ${featuredPost.tags.join(' · ')}</div>
          <button class="read-btn" data-slug="${featuredPost.slug}">Read full story →</button>
        </div>
      ` : ''}
      <div class="blog-grid" id="blogGrid"></div>
    `;

    mainContainer.innerHTML = html;

    const gridContainer = document.getElementById('blogGrid');
    if (filtered.length === 0) {
      gridContainer.innerHTML = `<div class="no-results"><i class="fas fa-newspaper"></i> <strong>No posts found</strong><br>Try different keywords or reset filters.</div>`;
    } else {
      gridContainer.innerHTML = filtered.map(post => `
        <div class="post-card" data-slug="${post.slug}">
          <img class="card-img" src="${post.image}" alt="${escapeHtml(post.title)}" loading="lazy">
          <div class="card-content">
            <div class="card-title">${escapeHtml(post.title)}</div>
            <div class="card-meta">
              <span><i class="far fa-calendar-alt"></i> ${post.date}</span>
              <span><i class="far fa-clock"></i> 4 min read</span>
            </div>
            <div class="card-tags">
              ${post.tags.map(t => `<span class="card-tag">${escapeHtml(t)}</span>`).join('')}
            </div>
          </div>
        </div>
      `).join('');

      // Attach click listeners to each card
      document.querySelectorAll('.post-card').forEach(card => {
        card.addEventListener('click', (e) => {
          e.stopPropagation();
          const slug = card.dataset.slug;
          showSinglePost(slug);
        });
      });
    }

    // Featured button listener
    const featuredBtn = document.querySelector('.featured .read-btn');
    if (featuredBtn) {
      featuredBtn.addEventListener('click', () => showSinglePost(featuredBtn.dataset.slug));
    }

    // Search handlers
    const searchBtn = document.getElementById('searchBtn');
    const searchInput = document.getElementById('searchInput');
    searchBtn.addEventListener('click', () => {
      currentSearchTerm = searchInput.value;
      renderHome();
    });
    searchInput.addEventListener('keyup', (e) => {
      if (e.key === 'Enter') {
        currentSearchTerm = searchInput.value;
        renderHome();
      }
    });

    // Tag chips dynamic event binding
    document.querySelectorAll('.tag-chip').forEach(chip => {
      chip.addEventListener('click', (e) => {
        const tag = chip.dataset.tag;
        currentFilterTag = tag;
        // preserve search term
        currentSearchTerm = document.getElementById('searchInput')?.value || '';
        renderHome();
      });
    });
  }

  // Display single post page with smooth transition
  function showSinglePost(slug) {
    const post = allPosts.find(p => p.slug === slug);
    if (!post) return;

    const postHtml = `
      <div class="post-page">
        <button class="back-btn" id="backHomeBtn"><i class="fas fa-arrow-left"></i> Back to all insights</button>
        <img src="${post.image}" alt="${escapeHtml(post.title)}">
        <h1>${escapeHtml(post.title)}</h1>
        <div class="post-meta-detail">
          <span><i class="far fa-calendar-alt"></i> ${post.date}</span>
          <span><i class="fas fa-tags"></i> ${post.tags.map(t => `#${t}`).join(' ')}</span>
        </div>
        <div class="post-content">${post.contentHtml}</div>
        <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--text-secondary);">
          <i class="fas fa-share-alt"></i> AIOWtech — exploring the intelligent frontier
        </div>
      </div>
    `;
    mainContainer.innerHTML = postHtml;
    const backBtn = document.getElementById('backHomeBtn');
    backBtn.addEventListener('click', () => {
      renderHome();
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Dark mode persistence
  function initDarkMode() {
    const storedTheme = localStorage.getItem('aiowtech_theme');
    if (storedTheme === 'dark') {
      document.body.classList.add('dark');
    }
    const toggleBtn = document.getElementById('darkModeToggle');
    toggleBtn.addEventListener('click', () => {
      document.body.classList.toggle('dark');
      const isDark = document.body.classList.contains('dark');
      localStorage.setItem('aiowtech_theme', isDark ? 'dark' : 'light');
      // optional icon toggle
      const icon = toggleBtn.querySelector('i');
      if (isDark) {
        icon.classList.remove('fa-moon');
        icon.classList.add('fa-sun');
      } else {
        icon.classList.remove('fa-sun');
        icon.classList.add('fa-moon');
      }
    });
    // set correct icon on load
    const icon = toggleBtn.querySelector('i');
    if (document.body.classList.contains('dark')) {
      icon.classList.remove('fa-moon');
      icon.classList.add('fa-sun');
    } else {
      icon.classList.remove('fa-sun');
      icon.classList.add('fa-moon');
    }
  }

  // Home link navigation
  function initNav() {
    const homeLink = document.getElementById('homeLink');
    homeLink.addEventListener('click', (e) => {
      e.preventDefault();
      currentFilterTag = 'all';
      currentSearchTerm = '';
      renderHome();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Loading animation then boot
  async function bootstrap() {
    // show loading spinner
    mainContainer.innerHTML = `
      <div class="loader">
        <div class="spinner"></div>
        <p><i class="fas fa-microchip"></i> loading AIOWtech insights ...</p>
      </div>
    `;
    await initPosts();
    initDarkMode();
    initNav();
    renderHome();
  }

  bootstrap();
</script>
</body>
</html>
